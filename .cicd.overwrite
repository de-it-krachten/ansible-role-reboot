---

generic:
  role_description: |
    Reboot a server
    By default, only when reboot is pending but it can be forced

# Supported platforms
platforms:
  sles15:
    supported: true
    ci: false
  sles16:
    supported: true
    ci: false
  opensuse15:
    supported: true
    ci: true
  opensuse16:
    supported: true
    ci: true
  ubuntu2004:
    supported: true
    ci: true

molecule:
  converge:
    vars:
      reboot_forced: true
